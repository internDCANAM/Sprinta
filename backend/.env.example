# Server
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://sprintaiso:sprintaiso_dev@localhost:5432/sprintaiso?schema=public

# Redis
REDIS_URL=redis://localhost:6379
REDIS_MAX_RETRIES=3

# JWT
JWT_ACCESS_SECRET=replace-with-32-byte-random-string
JWT_REFRESH_SECRET=replace-with-different-32-byte-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Admin bootstrap seed (pnpm backend db:seed) — not read by the app itself
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin

# Encryption — AES-256-GCM key, 32 bytes hex-encoded (64 hex chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace-with-64-hex-chars-representing-32-bytes

# Object storage (Cloudflare R2 — mocked with local dir for now)
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# CORS
CORS_ORIGIN=http://localhost:5173
