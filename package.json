{
  "name": "sprintaiso",
  "version": "0.1.0",
  "private": true,
  "description": "Sprintaiso kundportal — monorepo",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "pnpm -r typecheck",
    "backend": "pnpm --filter @sprintaiso/backend",
    "shared": "pnpm --filter @sprintaiso/shared",
    "db:up": "docker compose up -d postgres redis",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d postgres redis"
  },
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "devDependencies": {
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "typescript-eslint": "^8.62.1"
  }
}
