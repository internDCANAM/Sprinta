{
  "name": "sprintaiso",
  "version": "0.1.0",
  "private": true,
  "description": "Sprintaiso kundportal — monorepo",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "typecheck": "pnpm -r typecheck",
    "backend": "pnpm --filter @sprintaiso/backend",
    "db:up": "docker compose up -d postgres redis",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d postgres redis"
  },
  "type": "module",
  "packageManager": "pnpm@11.10.0",
  "devDependencies": {
    "@faker-js/faker": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-security": "^4.0.1",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "typescript-eslint": "^8.62.1"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "ioredis-mock": "^8.13.1",
    "node-mocks-http": "^1.18.0",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "vitest": "^4.1.10"
  }
}
